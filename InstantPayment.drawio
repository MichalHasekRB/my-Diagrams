        </mxCell>
        <mxCell id="qjQ1AYvx7mdl7HlHgLUF-56" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;span style=&quot;font-size: 17px;&quot;&gt;Služby na backendu&lt;/span&gt;&lt;/h1&gt;&lt;p&gt;&lt;font&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;Z pohledu IP mohou být nainstalované a běžet všechny - směřování volání je před&lt;/font&gt;&lt;br&gt;&lt;/font&gt;&lt;/p&gt;" vertex="1">
