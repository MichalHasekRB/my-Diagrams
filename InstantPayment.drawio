        </mxCell>
        <mxCell id="qjQ1AYvx7mdl7HlHgLUF-55" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;span style=&quot;font-size: 17px;&quot;&gt;Přepínač orchestrace&lt;/span&gt;&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;color: rgb(0, 0, 255);&quot;&gt;IMS má konfigurační parametry&lt;br&gt;INSTPAY_SOLUTION_VALIDATE&lt;br&gt;INSTPAY_SOLUTION_EVENT&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;color: rgb(0, 0, 255);&quot;&gt;(nutno nastavit hodnotu &lt;/font&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;withC24&lt;/font&gt;&lt;font style=&quot;color: rgb(0, 0, 255);&quot;&gt; nebo onlyTRS a restartovat službu)&lt;/font&gt;&lt;/p&gt;" vertex="1">
