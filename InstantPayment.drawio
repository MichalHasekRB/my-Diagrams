        <mxCell id="qjQ1AYvx7mdl7HlHgLUF-54" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;span style=&quot;font-size: 17px;&quot;&gt;Směřování MQ&lt;/span&gt;&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;color: rgb(0, 0, 255);&quot;&gt;Na WMB se podle DAPI směřuje na MQ fronty - bud pro WMB služby nebo IMS služby&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;color: rgb(0, 0, 255);&quot;&gt;IMS již komunikuje jen s IMS&lt;/font&gt;&lt;/p&gt;" vertex="1">
